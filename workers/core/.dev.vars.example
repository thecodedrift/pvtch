# Copy this file to .dev.vars and fill in your values

# Required: Your Twitch application client secret
# Get this from https://dev.twitch.tv/console/apps
TWITCH_SECRET=your_twitch_client_secret_here

# Optional: Override for local development
# TWITCH_REDIRECT_URI=http://localhost:8787/auth/callback
# PVTCH_APP_URL=http://localhost:8787

# Optional: Skip Twitch login entirely in dev by impersonating a user ID
# When set, all auth checks pass and this value is used as the Twitch user ID
# DEV_TWITCH_USER_ID=123456789

# Optional: Restrict this instance to specific Twitch usernames (comma-separated)
# When set, only these users can access widgets and OBS sources
# ALLOWED_USERS=alice,bob,charlie
